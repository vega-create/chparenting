---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../site.config';

// 5 「這裡有什麼」分類卡 — 對應 site.config 的 categories
const sections = [
  { emoji: '💛', name: '媽媽情緒',  desc: '理解自己，照顧自己的心，妳很重要。',     href: '/category/mom-emotions/',     icon: 'heart' },
  { emoji: '🔥', name: '育兒崩潰',  desc: '崩潰沒關係，這裡有陪伴與支持。',         href: '/category/parenting-crisis/', icon: 'fire'  },
  { emoji: '👩‍👧', name: '親子關係', desc: '和孩子一起成長，創造更美好時光。',       href: '/category/parent-child/',     icon: 'people' },
  { emoji: '🎓', name: '孩子學習',  desc: '學習不一定要完美，找到適合孩子的方式。', href: '/category/kids-learning/',    icon: 'cap'   },
  { emoji: '✨', name: '生活實用',  desc: '實用技巧與資源，讓生活更輕鬆。',         href: '/category/practical-life/',   icon: 'spark' },
];

// 多元背景 credentials
const credentials = [
  '兩個孩子的媽——女兒 2016 年生，兒子 2019 年生',
  '東海大學 數位創新管理碩士在學中',
  '7+ 年網路行銷經驗（內容、品牌、AI 工具整合）',
  '前兒童美語老師——多年陪伴 4-12 歲孩子學習，輔以日文研修背景',
  '長期接觸心靈、自我成長與身心修復相關工作',
  'AiMommyWisdom 創辦人——幫媽媽把 AI 帶進育兒、工作和生活',
];
---

<BaseLayout
  title="關於薇佳媽咪 — 媽媽生活復原力 Lab"
  description="嗨，我是薇佳媽咪。一個相信「媽媽不需要完美」的空間，陪妳一起走過育兒、工作、家庭與自己的每一天。"
>
  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="bg-gradient-to-b from-peach-50 to-peach-100 overflow-hidden">
    <div class="max-w-7xl mx-auto px-5 pt-10 md:pt-14 pb-12 md:pb-16 grid lg:grid-cols-2 gap-10 items-center">
      <div>
        <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-peach-600 bg-white/85 px-3 py-1.5 rounded-full mb-5">
          <span aria-hidden="true">♡</span> 關於我
        </span>
        <h1 class="font-display text-warmgray-800 leading-[1.15] text-3xl md:text-4xl lg:text-5xl mb-5">
          嗨，我是薇佳媽咪 <span aria-hidden="true">☀️</span>
        </h1>
        <p class="text-warmgray-600 text-base mb-2">一個相信</p>
        <p class="font-display text-peach-500 text-2xl md:text-3xl font-bold mb-3">
          「媽媽不需要完美」
        </p>
        <p class="text-warmgray-700 text-base md:text-lg mb-5">
          只需要一個能喘口氣的空間。
        </p>
        <p class="text-warmgray-600 leading-relaxed max-w-lg text-sm md:text-base">
          陪妳一起走過育兒、工作、家庭與自己的每一天，
          在這裡，妳可以被理解、被支持，也能找到力量。
        </p>
        <p class="text-2xl text-peach-400 mt-4" aria-hidden="true">♡</p>
      </div>
      <div class="relative">
        <div class="aspect-[5/4] rounded-3xl overflow-hidden bg-gradient-to-br from-peach-100 via-cream to-peach-50 shadow-md flex items-center justify-center text-warmgray-500 text-sm">
          <span class="opacity-60">薇佳媽咪寫日誌的照片</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ 我的故事 ═══════════════ -->
  <section class="max-w-7xl mx-auto px-5 py-14 grid lg:grid-cols-[1fr_1.05fr] gap-10 items-center">
    <div class="relative">
      <div class="aspect-[5/4] rounded-3xl overflow-hidden bg-gradient-to-br from-cream via-peach-50 to-peach-100 shadow-md flex items-center justify-center text-warmgray-500 text-sm">
        <span class="opacity-60">媽媽和孩子一起讀繪本的照片</span>
      </div>
    </div>
    <div>
      <h2 class="font-display text-2xl md:text-3xl text-warmgray-800 mb-1 pb-2 inline-block border-b-2 border-peach-400">
        我的故事
      </h2>
      <p class="text-warmgray-700 leading-relaxed mt-5 mb-3">
        半夜三點的崩潰、孩子哭不停的無助、工作與家庭之間的拉扯，<strong class="text-warmgray-800">我都親身經歷過</strong>。
      </p>
      <p class="text-warmgray-700 leading-relaxed mb-3">
        那天凌晨三點，小的剛哭完睡著，大的又爬起來說肚子餓。我坐在廚房地板上，拿出手機搜尋「帶小孩好累怎麼辦」，卻找不到一篇讓我覺得**有人懂我**的文章。
      </p>
      <p class="text-warmgray-700 leading-relaxed mb-3">
        那些文章要嘛太專業冰冷，要嘛都在說教。我只是想找到一個人跟我說：「妳不是一個人，妳已經做得很好了。」
      </p>
      <p class="text-warmgray-700 leading-relaxed mb-5">
        所以我希望打造一個地方，讓媽媽知道：
      </p>
      <p class="font-display italic text-peach-500 text-xl flex items-center gap-2">
        <span aria-hidden="true">♡</span> 妳不孤單，我們都在這裡陪妳。
      </p>
    </div>
  </section>

  <!-- ═══════════════ 我的專業背景 ═══════════════ -->
  <section class="px-5 py-10">
    <div class="max-w-5xl mx-auto bg-peach-50 rounded-3xl py-10 px-6 md:px-10">
      <div class="text-center mb-7">
        <h2 class="font-display text-2xl md:text-3xl text-warmgray-800 mb-2 flex items-center justify-center gap-2">
          <span class="text-peach-400">♡</span> 我的專業背景 <span class="text-peach-400">♡</span>
        </h2>
        <p class="text-warmgray-600 text-sm">這個網站的內容來自於三條線交織的視角：教育、心靈、商業。</p>
      </div>
      <ul class="list-none m-0 p-0 grid md:grid-cols-2 gap-3 max-w-3xl mx-auto">
        {credentials.map((c) => (
          <li class="flex items-start gap-3 bg-white rounded-2xl p-4 shadow-sm">
            <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-peach-100 text-peach-600 shrink-0 mt-0.5" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="m5 12 5 5 9-11"/></svg>
            </span>
            <span class="text-sm text-warmgray-700 leading-relaxed">{c}</span>
          </li>
        ))}
      </ul>
      <p class="text-center text-xs text-warmgray-500 mt-6 max-w-2xl mx-auto leading-relaxed">
        這個網站的所有內容都經過仔細整理，參考台灣權威來源（衛福部、國民健康署、台灣兒科醫學會、親子天下）以及國際資源（AAP、WHO、ACOG）。
      </p>
    </div>
  </section>

  <!-- ═══════════════ 這裡有什麼？ ═══════════════ -->
  <section class="max-w-7xl mx-auto px-5 py-12">
    <div class="text-center mb-10">
      <h2 class="font-display text-2xl md:text-3xl text-warmgray-800 mb-2 flex items-center justify-center gap-2">
        <span class="text-peach-400 text-lg">‿</span> 這裡有什麼？ <span class="text-peach-400 text-lg">‿</span>
      </h2>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
      {sections.map((s) => (
        <a href={s.href} class="group block bg-peach-50 hover:bg-peach-100 rounded-2xl p-5 text-center no-underline transition-colors">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-peach-400 text-white mx-auto mb-3 text-2xl shadow-sm" aria-hidden="true">
            {s.icon === 'heart'  && <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7-4.5-9.5-9C.8 8.8 2.6 5 6.2 5c2 0 3.4 1.1 4.3 2.5C11.4 6.1 12.8 5 14.8 5c3.6 0 5.4 3.8 3.7 7C19 16.5 12 21 12 21z"/></svg>}
            {s.icon === 'fire'   && <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2s-3 4-3 7c0 2 1 3 1 5 0 0-3-2-3-5-1 1-3 4-3 7a6 6 0 1 0 12 0c0-3-1-5-2-7-1-2-2-7-2-7z"/></svg>}
            {s.icon === 'people' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="7" r="3"/><circle cx="17" cy="9" r="2.5"/><path d="M3 21v-1a6 6 0 0 1 12 0v1"/><path d="M14 21v-1a4 4 0 0 1 7-2"/></svg>}
            {s.icon === 'cap'    && <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3 1 9l11 6 9-4.9V17h2V9z"/><path d="M5 13.2v4l7 3.8 7-3.8v-4l-7 3.8z"/></svg>}
            {s.icon === 'spark'  && <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.5 4.5L18 8l-4.5 1.5L12 14l-1.5-4.5L6 8l4.5-1.5z"/><path d="M19 14l.8 2.2L22 17l-2.2.8L19 20l-.8-2.2L16 17l2.2-.8z"/><path d="M5 16l.6 1.6L7 18l-1.4.4L5 20l-.6-1.6L3 18l1.4-.4z"/></svg>}
          </div>
          <h3 class="font-display font-bold text-warmgray-800 mb-1.5">{s.name}</h3>
          <p class="text-xs text-warmgray-600 leading-relaxed">{s.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- ═══════════════ 我的理念 ═══════════════ -->
  <section class="max-w-4xl mx-auto px-5 py-10">
    <h2 class="font-display text-2xl md:text-3xl text-warmgray-800 mb-5 text-center">
      我的理念 <span class="text-peach-400">♡</span>
    </h2>
    <div class="bg-white rounded-3xl p-7 md:p-10 shadow-sm space-y-4">
      <p class="text-warmgray-700 leading-relaxed">
        我相信每個媽媽都已經<strong class="text-warmgray-800">在用自己的方式努力了</strong>。社會對媽媽的期待太高了——要會煮飯、要有耐心、要會教小孩、要維持身材、最好還要有自己的事業。
      </p>
      <p class="text-warmgray-700 leading-relaxed">
        但真實的育兒生活就是一團混亂，<strong class="text-warmgray-800">而這完全沒關係</strong>。這個網站存在的意義，就是讓妳在混亂中找到一些方法、一些安慰、和一些「原來不是只有我這樣」的共鳴。
      </p>
      <p class="text-warmgray-700 leading-relaxed">
        我把教育、心靈和商業這三條我自己也在走的路，整理成媽媽可以用的內容、工具和練習。<strong class="text-warmgray-800">不是教妳成為完美媽媽，是陪妳在不完美裡也能站穩。</strong>
      </p>
    </div>
  </section>

  <!-- ═══════════════ 今天的妳辛苦了 CTA ═══════════════ -->
  <section class="max-w-7xl mx-auto px-5 py-10">
    <div class="bg-gradient-to-r from-peach-50 via-peach-100 to-cream rounded-3xl py-8 px-6 md:px-10 grid md:grid-cols-[1fr_auto] gap-6 items-center">
      <div>
        <h2 class="font-display text-warmgray-800 text-2xl md:text-3xl mb-3 flex items-center gap-2">
          今天的妳辛苦了 <span class="text-peach-400">♡</span>
        </h2>
        <p class="text-warmgray-700 leading-relaxed mb-1">休息不是偷懶，而是充電。</p>
        <p class="text-warmgray-700 leading-relaxed mb-5">給自己一點時間喘口氣吧！</p>
        <a href="/posts/" class="inline-flex items-center gap-2 bg-peach-400 hover:bg-peach-500 text-white text-sm font-semibold px-6 py-3 rounded-full no-underline transition-colors">
          去逛逛文章 <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="aspect-[4/3] md:w-72 rounded-2xl overflow-hidden bg-gradient-to-br from-peach-200 via-cream to-peach-100 shadow-md flex items-center justify-center text-warmgray-500 text-xs">
        <span class="opacity-60">茶 + 日誌 cozy 照片</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════ 想跟我說話 ═══════════════ -->
  <section class="max-w-3xl mx-auto px-5 py-10 pb-14 text-center">
    <h3 class="font-display text-xl text-warmgray-800 mb-3">想跟我說話？</h3>
    <p class="text-warmgray-600 text-sm leading-relaxed mb-5">
      如果妳有任何想法、建議、或只是想找人聊聊，歡迎到我的<br/>
      Facebook 粉絲專頁留言或私訊我。
      不管是分享妳的育兒故事、推薦想看的主題、或告訴我哪篇文章幫到妳——<br/>
      <strong class="text-warmgray-700">妳的每一個訊息，我都會認真看</strong> <span class="text-peach-400">♡</span>
    </p>
    <a
      href={siteConfig.social.facebook}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 bg-white border-2 border-peach-400 hover:bg-peach-50 text-peach-600 text-sm font-semibold px-6 py-2.5 rounded-full no-underline transition-colors"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 5.99 4.39 10.96 10.13 11.85v-8.38H7.08v-3.47h3.05V9.43c0-3 1.79-4.67 4.53-4.67 1.31 0 2.69.23 2.69.23v2.96h-1.52c-1.49 0-1.96.93-1.96 1.88v2.24h3.33l-.53 3.47h-2.8v8.38C19.61 23.03 24 18.06 24 12.07z"/></svg>
      到 Facebook 找我聊聊
    </a>

    <blockquote class="mt-10 text-warmgray-600 italic text-base border-l-4 border-peach-400 pl-5 text-left max-w-xl mx-auto">
      「媽媽不需要完美，只需要一個能喘口氣的地方。」
    </blockquote>
  </section>
</BaseLayout>
