---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  primaryColor: string;
  bgColor: string;
  igHandle: string;
  igUrl: string;
}

const { title, description, primaryColor, bgColor, igHandle, igUrl } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>
  <slot />
</BaseLayout>
