---
import SEO from '../components/SEO.astro';
import Analytics from '../components/Analytics.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WebSiteSchema from '../components/WebSiteSchema.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  publishDate?: Date;
  noindex?: boolean;
}

const { title, description, image, type, publishDate, noindex } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
  {/*
    EzoicAds JavaScript Integration — must sit at the very top of <head>.
    Order matters: privacy CMP scripts (data-cfasync="false") MUST load
    BEFORE the header script so Cloudflare/Rocket-Loader doesn't reorder
    them. Docs: https://docs.ezoic.com/docs/ezoicads/integration/
  */}
  <script is:inline data-cfasync="false" src="https://cmp.gatekeeperconsent.com/min.js"></script>
  <script is:inline data-cfasync="false" src="https://the.gatekeeperconsent.com/cmp.min.js"></script>
  <script is:inline async src="//www.ezojs.com/ezoic/sa.min.js"></script>
  <script is:inline>
    window.ezstandalone = window.ezstandalone || {};
    window.ezstandalone.cmd = window.ezstandalone.cmd || [];
  </script>
  <script is:inline src="//ezoicanalytics.com/analytics.js"></script>

  <SEO
    title={title}
    description={description}
    image={image}
    type={type}
    publishDate={publishDate}
  />
  <Analytics />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- WebSite + Organization Schema (every page, family-wide sameAs) -->
  <WebSiteSchema />
</head>
<body class="min-h-screen flex flex-col">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
