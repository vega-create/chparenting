---
import SEO from '../components/SEO.astro';
import Analytics from '../components/Analytics.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WebSiteSchema from '../components/WebSiteSchema.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  publishDate?: Date;
  noindex?: boolean;
}

const { title, description, image, type, publishDate, noindex } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <SEO
    title={title}
    description={description}
    image={image}
    type={type}
    publishDate={publishDate}
  />
  <Analytics />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- WebSite + Organization Schema (every page, family-wide sameAs) -->
  <WebSiteSchema />
<!-- Teleworker ad network -->
<script src="https://storage.googleapis.com/teleworker-public-storage/gad_js/net.min.js" async></script>
</head>
<body class="min-h-screen flex flex-col">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
